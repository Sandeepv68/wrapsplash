{
  "name": "wrapsplash",
  "version": "5.0.0",
  "description": "A simple npm wrapper module to use the popular Unsplash API.",
  "private": false,
  "main": "dist/wrapsplash.umd.js",
  "module": "dist/wrapsplash.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/wrapsplash.es.js",
      "require": "./dist/wrapsplash.umd.js",
      "default": "./dist/wrapsplash.umd.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test lib --ext .ts",
    "release": "npm run build && npm publish",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SandeepVattapparambil/wrapsplash.git"
  },
  "keywords": [
    "Unsplash",
    "API",
    "wrapper",
    "Images",
    "Photos"
  ],
  "author": "Sandeep Vattapparambil",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SandeepVattapparambil/wrapsplash/issues"
  },
  "homepage": "https://github.com/SandeepVattapparambil/wrapsplash#readme",
  "dependencies": {
    "axios": "^1.6.1",
    "crypto-js": "^4.1.1"
  },
  "directories": {
    "examples": "examples"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
